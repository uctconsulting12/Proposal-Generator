# JD Proposal Copilot configuration.
# Copy to ".env" and adjust. All variables are prefixed with COPILOT_.

# --- HTTP server ---
COPILOT_HOST=127.0.0.1
COPILOT_PORT=8080
# JSON list of allowed CORS origins, e.g. ["http://localhost:5173"]
COPILOT_CORS_ORIGINS=["*"]

# --- Cloud database (MongoDB) ---
# ALL durable data lives here: accounts, profiles, chat sessions, uploaded
# knowledge-base documents (bytes in GridFS), and company logos. Point this
# at a cloud cluster so users see the same data from any device.
# Local default uses MongoDB on this machine. For the cloud, create a free
# MongoDB Atlas cluster and paste its connection string here, e.g.:
#   COPILOT_MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/?retryWrites=true&w=majority
COPILOT_MONGODB_URI=mongodb://localhost:27017
COPILOT_MONGODB_DB_NAME=jd_copilot_auth

# --- Authentication (JWT) ---
# Per-user JWT auth backed by the MongoDB above.
# Change this in production.
COPILOT_JWT_SECRET=change-me-in-env
COPILOT_JWT_ALGORITHM=HS256
COPILOT_JWT_EXP_MINUTES=1440

# --- LLM provider ---
# "ollama" = local Ollama server, "gemini" = Google Gemini API
COPILOT_LLM_PROVIDER=ollama

# Model name (interpreted per provider).
#   ollama:  qwen3:14b, llama3:8b, etc.
#   gemini:  gemini-2.5-flash, gemini-2.5-pro, gemini-1.5-flash, etc.
COPILOT_MODEL_NAME=qwen3:14b

# Gemini settings (used when COPILOT_LLM_PROVIDER=gemini).
# Get a key at https://aistudio.google.com/app/apikey
COPILOT_GEMINI_API_KEY=

# Ollama settings (used when COPILOT_LLM_PROVIDER=ollama).
COPILOT_OLLAMA_URL=http://localhost:11434/api/chat
# Embedding model for RAG, served by the same Ollama host (pull it once:
# `ollama pull nomic-embed-text`). Running embeddings remotely keeps the
# deployed app small enough for a 512 MB instance.
COPILOT_OLLAMA_EMBED_MODEL=nomic-embed-text

COPILOT_LLM_TIMEOUT_S=180
COPILOT_LLM_MAX_RETRIES=2

# --- Proposal workflow ---
# true  = ask a few clarifying questions before drafting the proposal
# false = skip questions and go straight to the draft proposal
COPILOT_ENABLE_QUESTIONS=true
# Max clarifying questions before the draft is shown (keep this small).
COPILOT_MAX_QUESTIONS=2
# Company / brand name printed on the exported proposal PDF (blank = omit).
COPILOT_PDF_BRAND_NAME=

# --- RAG ---
COPILOT_EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
COPILOT_RETRIEVAL_TOP_K=4
COPILOT_CHUNK_SIZE=900
COPILOT_CHUNK_OVERLAP=150

# --- Session limits ---
COPILOT_MAX_SESSIONS=500
COPILOT_MAX_MESSAGES_PER_SESSION=60

# --- Logging ---
COPILOT_LOG_LEVEL=INFO
# Set to true for single-line JSON logs (machine-parseable).
COPILOT_LOG_JSON=false
